---
/**
 * @file src/components/Footer.astro
 * @description Standard full-width application footer rendering metadata logs.
 */
---

<footer
    class="max-w-6xl mx-auto px-6 py-12 w-full flex flex-col md:flex-row justify-between items-center gap-6 text-xs relative z-10 mt-auto"
>
    <!-- Author Attribution -->
    <div class="text-slate-500">
        &copy; 2026
        <span
            class="font-bold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 ml-1"
        >
            ÆSoul
        </span>. All rights reserved.
    </div>

    <!-- System/Build version identifier logs -->
    <div class="text-slate-600 font-mono tracking-wider">
        CodeForge v1.2
    </div>
</footer>
