---
/**
 * src/components/HeroBento.astro
 * * Architecture Component: Hero Bento Grid
 * Responsibility: Renders the primary above-the-fold identity modules (Value Proposition,
 * Bio interaction card, and Tech Stack highlights).
 */
---

<div
    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 auto-rows-[minmax(200px,auto)]"
>
    <article
        class="glass-card hover-glow lg:col-span-2 lg:row-span-2 p-10 flex flex-col justify-center group overflow-hidden relative"
    >
        <div
            class="absolute inset-0 bg-blue-600/5 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none z-0"
        >
        </div>
        <h1
            class="text-5xl lg:text-6xl font-extrabold tracking-tight mb-8 text-white relative z-10 leading-[1.1]"
        >
            Building<br />digital<br />
            <span
                class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500"
                >experiences.</span
            >
        </h1>
        <a href="#progetti" class="btn-explore relative z-10">
            Explore Works
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
        </a>
    </article>

    <article
        class="glass-card hover-glow lg:col-span-2 lg:row-span-1 grid group overflow-hidden cursor-pointer focus:outline-none active:scale-[0.97] transition-all duration-300"
        tabindex="0"
    >
        <div
            class="col-start-1 row-start-1 flex flex-col items-center justify-center p-8 transition-all duration-500 ease-in-out group-hover:opacity-0 group-focus:opacity-0 group-hover:-translate-y-8 group-focus:-translate-y-8 z-20"
        >
            <div
                class="w-16 h-16 rounded-2xl bg-gradient-to-br from-white/10 to-white/5 border border-white/10 flex items-center justify-center mb-5 text-white shadow-2xl relative"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="30"
                    height="30"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"
                    ></path><circle cx="12" cy="7" r="4"></circle>
                </svg>
            </div>
            <h2
                class="text-2xl font-black tracking-[0.2em] text-white uppercase"
            >
                About Me
            </h2>

            <div class="mt-4 flex items-center gap-2.5">
                <div class="tap-only items-center gap-2 animate-tap-pulse">
                    <div class="relative flex items-center justify-center">
                        <img
                            src="/tap.png"
                            alt="Tap context icon"
                            class="w-5 h-5 object-contain invert"
                        />
                    </div>
                    <span
                        class="text-cyan-400 text-[10px] font-bold uppercase tracking-widest"
                        >Tap to reveal</span
                    >
                </div>
                <div class="hover-only items-center gap-2">
                    <svg
                        class="w-3.5 h-3.5 text-cyan-400 animate-bounce"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        stroke-width="2.5"
                    >
                        <path d="M3 3l7.07 16.97 2.51-7.39 7.39-2.51L3 3z"
                        ></path>
                    </svg>
                    <span
                        class="text-cyan-400 text-[10px] font-bold uppercase tracking-widest"
                        >Hover to reveal</span
                    >
                </div>
            </div>
        </div>

        <div
            class="col-start-1 row-start-1 p-8 flex flex-col justify-center transition-all duration-500 ease-in-out opacity-0 translate-y-8 group-hover:opacity-100 group-focus:opacity-100 group-hover:translate-y-0 group-focus:translate-y-0 z-10"
        >
            <h3 class="text-xl font-bold text-white mb-3">
                Hi, I'm <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-400"
                    >Samuele Arabia</span
                >
            </h3>
            <p class="text-slate-300 text-[13px] leading-relaxed mb-5">
                <span
                    class="inline-flex items-center px-2 py-0.5 rounded-md bg-blue-500/10 text-blue-400 border border-blue-500/20 text-[10px] font-bold uppercase mr-1.5 shadow-[0_0_10px_rgba(59,130,246,0.1)]"
                >
                    🎓 Computer Engineering UNDERGRADUATE
                </span>
                Passionately building digital experiences through clean code and modern
                architecture.
            </p>
            <div
                class="mt-auto pt-4 border-t border-white/[0.05] flex items-center gap-3"
            >
                <div
                    class="w-9 h-9 rounded-xl bg-cyan-500/10 border border-cyan-500/20 flex items-center justify-center text-cyan-400 shadow-inner flex-shrink-0"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <polyline points="16 18 22 12 16 6"></polyline><polyline
                            points="8 6 2 12 8 18"></polyline>
                    </svg>
                </div>
                <p class="text-slate-400 text-sm">
                    Focused on <span class="text-white font-semibold"
                        >full-stack development</span
                    >.
                </p>
            </div>
        </div>
    </article>

    <article
        class="glass-card hover-glow p-8 flex flex-col justify-center items-center text-center group"
    >
        <div
            class="w-12 h-12 bg-cyan-500/10 text-cyan-400 rounded-xl flex items-center justify-center mb-3 group-hover:-translate-y-1 transition-transform"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline
                    points="2 17 12 22 22 17"></polyline><polyline
                    points="2 12 12 17 22 12"></polyline>
            </svg>
        </div>
        <h3 class="text-white font-bold text-sm">Frontend</h3>
        <p class="text-slate-400 text-[10px] mt-1">Astro · React · Tailwind</p>
    </article>

    <article
        class="glass-card hover-glow p-8 flex flex-col justify-center items-center text-center group"
    >
        <div
            class="w-12 h-12 bg-blue-500/10 text-blue-400 rounded-xl flex items-center justify-center mb-3 group-hover:-translate-y-1 transition-transform"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <ellipse cx="12" cy="5" rx="9" ry="3"></ellipse>
                <path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"></path><path
                    d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3"></path>
            </svg>
        </div>
        <h3 class="text-white font-bold text-sm">Backend</h3>
        <p class="text-slate-400 text-[10px] mt-1">Node · Fastify · MongoDB</p>
    </article>
</div>
