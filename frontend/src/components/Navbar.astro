---
/**
 * @file src/components/Navbar.astro
 * @description Global navigation bar. Contains the brand logo and optimized SVG social links,
 * including a newly configured direct mail route with a custom red hover state.
 */
---

<nav
    class="max-w-6xl mx-auto px-6 py-8 w-full flex justify-between items-center z-50 relative pointer-events-auto"
>
    <span
        class="text-2xl md:text-3xl font-bold tracking-tighter text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500 drop-shadow-[0_0_15px_rgba(6,182,212,0.4)]"
    >
        CodeForge.
    </span>

    <div
        class="flex items-center gap-2 bg-slate-900/30 backdrop-blur-md border border-white/10 px-4 py-1.5 rounded-full shadow-lg"
    >
        <span
            class="hidden md:block text-xs font-bold text-slate-400 mr-1 uppercase tracking-wider"
        >
            Find me on
        </span>

        <a
            href="https://www.linkedin.com/in/samuele-arabia-3aa255302/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="social-link linkedin"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path
                    d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                ></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
            </svg>
        </a>

        <a
            href="https://github.com/AeSoul0"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="social-link github"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path
                    d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
                ></path>
            </svg>
        </a>

        <a
            href="https://api.whatsapp.com/send?phone=393880555074"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="WhatsApp"
            class="social-link whatsapp"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path
                    d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"
                ></path>
            </svg>
        </a>

        <a
            href="mailto:samuelearabia10@gmail.com"
            aria-label="Email"
            class="social-link mail"
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                ></path>
                <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
        </a>
    </div>
</nav>

<style>
    /* Simulates the global interaction behavior specifically mapped to a red color profile */
    .social-link.mail:hover {
        background-color: #ef4444; /* Deep red core */
        color: #ffffff;
        transform: scale(1.15) translateY(-3px);
        box-shadow: 0 8px 20px rgba(239, 68, 68, 0.4); /* Glowing red shadow */
    }
</style>
