---
/**
 * @file src/components/ParticleCanvas.astro
 * @description Self-contained HTML5 Canvas component computing real-time mouse interactive network node simulations.
 */
---

<!-- Interactive layer for cosmic/particle nodes -->
<canvas id="particleCanvas"></canvas>

<style>
    #particleCanvas {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
        pointer-events: none;
    }
</style>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const canvas = document.getElementById("particleCanvas");
        if (!canvas) return;

        const ctx = canvas.getContext("2d");
        let w,
            h,
            particles = [];
        let mouse = { x: null, y: null };

        // Updates drawing bounds dynamically without disrupting viewport scaling
        const resize = () => {
            w = canvas.width = window.innerWidth;
            h = canvas.height = window.innerHeight;
        };
        window.addEventListener("resize", resize);
        resize();

        // Mouse coordinates capturing loops
        window.addEventListener("mousemove", (e) => {
            mouse.x = e.clientX;
            mouse.y = e.clientY;
        });
        window.addEventListener("mouseout", () => {
            mouse.x = null;
            mouse.y = null;
        });

        // Particle structural node architecture
        class Particle {
            constructor() {
                this.x = Math.random() * w;
                this.y = Math.random() * h;
                this.vx = (Math.random() - 0.5) * 0.6;
                this.vy = (Math.random() - 0.5) * 0.6;
                this.baseColor =
                    Math.random() > 0.5 ? "6, 182, 212" : "99, 102, 241";
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;

                // Rigid borders reflecting logic
                if (this.x < 0 || this.x > w) this.vx *= -1;
                if (this.y < 0 || this.y > h) this.vy *= -1;
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, 1.2, 0, Math.PI * 2);
                ctx.fillStyle = `rgba(${this.baseColor}, 0.6)`;
                ctx.fill();
            }
        }

        // Allocate network particles allocation load
        for (let i = 0; i < 55; i++) {
            particles.push(new Particle());
        }

        // Main execution rendering loop running inside the native animation thread
        function animate() {
            ctx.clearRect(0, 0, w, h);

            for (let i = 0; i < particles.length; i++) {
                particles[i].update();
                particles[i].draw();

                // Compute structural vectors linking adjacent nodes
                for (let j = i + 1; j < particles.length; j++) {
                    let dx = particles[i].x - particles[j].x;
                    let dy = particles[i].y - particles[j].y;
                    let distance = Math.sqrt(dx * dx + dy * dy);

                    if (distance < 110) {
                        ctx.beginPath();
                        ctx.strokeStyle = `rgba(${particles[i].baseColor}, ${0.12 - distance / 900})`;
                        ctx.lineWidth = 0.7;
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }

                // Draw physical links tracking coordinates to mouse positioning
                if (mouse.x !== null && mouse.y !== null) {
                    let dx = particles[i].x - mouse.x;
                    let dy = particles[i].y - mouse.y;
                    let distance = Math.sqrt(dx * dx + dy * dy);

                    if (distance < 160) {
                        ctx.beginPath();
                        ctx.strokeStyle = `rgba(6, 182, 212, ${0.25 - distance / 640})`;
                        ctx.lineWidth = 0.9;
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(mouse.x, mouse.y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(animate);
        }
        animate();
    });
</script>
