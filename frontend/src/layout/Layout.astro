---
/**
 * src/layouts/Layout.astro
 * * Architecture Layer: Root Layout
 * Responsibility: Provides the fundamental HTML document structure, metadata (SEO),
 * global CSS tokens, and core client-side scripting. Wraps all page content via <slot />.
 */

export interface Props {
    title: string;
}

const { title } = Astro.props;
---

<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="AeSoul_favicon.ico" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
            rel="stylesheet"
        />

        <style is:global>
            /* ==========================================
               🎨 GLOBAL DESIGN SYSTEM & TOKENS
               ========================================== */

            html,
            body {
                margin: 0;
                padding: 0;
                background-color: #020617;
                color: #e2e8f0;
                font-family: "Outfit", sans-serif;
            }

            body {
                visibility: hidden;
            }
            .loaded body {
                visibility: visible;
            }

            @keyframes blob {
                0% {
                    transform: translate(0px, 0px) scale(1);
                }
                33% {
                    transform: translate(30px, -30px) scale(1.1);
                }
                66% {
                    transform: translate(-20px, 20px) scale(0.9);
                }
                100% {
                    transform: translate(0px, 0px) scale(1);
                }
            }
            .animate-blob {
                animation: blob 12s infinite alternate ease-in-out;
            }
            .animation-delay-2000 {
                animation-delay: 2s;
            }
            .animation-delay-4000 {
                animation-delay: 4s;
            }

            .glass-card {
                background: rgba(255, 255, 255, 0.03);
                backdrop-filter: blur(20px) saturate(160%);
                -webkit-backdrop-filter: blur(20px) saturate(160%);
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                border-left: 1px solid rgba(255, 255, 255, 0.1);
                border-right: 1px solid rgba(255, 255, 255, 0.02);
                border-bottom: 1px solid rgba(255, 255, 255, 0.02);
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
                transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
                border-radius: 2rem;
                position: relative;
            }

            .hover-glow:hover {
                transform: translateY(-6px);
                border-color: rgba(59, 130, 246, 0.8) !important;
                box-shadow:
                    0 15px 35px rgba(0, 0, 0, 0.5),
                    0 0 25px rgba(59, 130, 246, 0.3),
                    inset 0 0 15px rgba(59, 130, 246, 0.1);
            }

            .btn-explore {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.6rem 1.4rem;
                border-radius: 9999px;
                font-weight: 600;
                font-size: 0.8rem;
                color: #fff;
                background: rgba(6, 182, 212, 0.1);
                border: 1px solid rgba(6, 182, 212, 0.3);
                transition: all 0.3s ease;
                text-decoration: none;
                width: fit-content;
            }
            .btn-explore:hover {
                background: rgba(6, 182, 212, 0.2);
                border-color: rgba(6, 182, 212, 0.8);
                transform: scale(1.05);
            }

            .section-divider {
                height: 2px;
                width: 100%;
                background: linear-gradient(
                    90deg,
                    transparent 0%,
                    rgba(6, 182, 212, 0.6) 50%,
                    transparent 100%
                );
                margin: 4rem 0;
                box-shadow: 0 0 15px rgba(6, 182, 212, 0.4);
            }

            .tap-only {
                display: flex;
            }
            .hover-only {
                display: none;
            }
            @media (hover: hover) {
                .tap-only {
                    display: none;
                }
                .hover-only {
                    display: flex;
                }
            }

            @keyframes pulse-fade-blur {
                0%,
                100% {
                    opacity: 1;
                    filter: blur(0px);
                }
                50% {
                    opacity: 0.6;
                    filter: blur(0.5px);
                }
            }
            .animate-tap-pulse {
                animation: pulse-fade-blur 2s infinite ease-in-out;
            }
        </style>
    </head>
    <body
        class="min-h-screen flex flex-col relative selection:bg-cyan-500 selection:text-white"
    >
        <slot />

        <script is:inline>
            document.addEventListener("DOMContentLoaded", () => {
                // Display layout securely to prevent FOUC
                document.documentElement.classList.add("loaded");

                // Scroll Telemetry logic for History Hash manipulation
                const projectsSection = document.getElementById("progetti");
                if (projectsSection) {
                    window.addEventListener("scroll", () => {
                        const viewportScrollContext =
                            window.scrollY + window.innerHeight / 2;
                        const targetThreshold = projectsSection.offsetTop;
                        if (viewportScrollContext >= targetThreshold) {
                            if (window.location.hash !== "#progetti")
                                history.replaceState(null, null, "#progetti");
                        } else {
                            if (window.location.hash === "#progetti")
                                history.replaceState(
                                    null,
                                    null,
                                    window.location.pathname +
                                        window.location.search,
                                );
                        }
                    });
                }
            });
        </script>
    </body>
</html>
