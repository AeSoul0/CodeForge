---
/**
 * @file src/layout/Layout.astro
 * @description Master Layout file establishing HTML skeleton, fonts, global CSS effects, and animated background blobs.
 */

export interface Props {
    title?: string;
}

const { title = "CodeForge | ÆSoul" } = Astro.props;
---

<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/AeSoul_favicon.ico" />
        <meta name="viewport" content="width=device-width" />
        <title>{title}</title>

        <!-- Preconnecting and loading fonts for optimized typography performance -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
            rel="stylesheet"
        />

        <style is:global>
            /* Global CSS resets and theme initialization */
            html,
            body {
                margin: 0;
                padding: 0;
                background-color: #020617;
                color: #e2e8f0;
                font-family: "Outfit", sans-serif;
            }

            /* Prevent flash of unstyled/uninitialized layout content */
            body {
                visibility: hidden;
            }
            .loaded body {
                visibility: visible;
            }

            /* Keyframe animations for fluid ambient background blobs */
            @keyframes blob {
                0% {
                    transform: translate(0px, 0px) scale(1);
                }
                33% {
                    transform: translate(30px, -30px) scale(1.1);
                }
                66% {
                    transform: translate(-20px, 20px) scale(0.9);
                }
                100% {
                    transform: translate(0px, 0px) scale(1);
                }
            }
            .animate-blob {
                animation: blob 12s infinite alternate ease-in-out;
            }

            /* Core design token: Glassmorphism layout structure */
            .glass-card {
                background: rgba(255, 255, 255, 0.03);
                backdrop-filter: blur(20px) saturate(160%);
                -webkit-backdrop-filter: blur(20px) saturate(160%);
                border-top: 1px solid rgba(255, 255, 255, 0.1);
                border-left: 1px solid rgba(255, 255, 255, 0.1);
                border-right: 1px solid rgba(255, 255, 255, 0.02);
                border-bottom: 1px solid rgba(255, 255, 255, 0.02);
                box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
                transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
                border-radius: 2rem;
                position: relative;
            }

            /* Interactive state: Outer cybernetic glow effect */
            .hover-glow:hover {
                transform: translateY(-6px);
                border-color: rgba(59, 130, 246, 0.8) !important;
                box-shadow:
                    0 15px 35px rgba(0, 0, 0, 0.5),
                    0 0 25px rgba(59, 130, 246, 0.3),
                    inset 0 0 15px rgba(59, 130, 246, 0.1);
            }

            /* Call to Action components visual styling */
            .btn-explore {
                display: inline-flex;
                align-items: center;
                gap: 0.5rem;
                padding: 0.6rem 1.4rem;
                border-radius: 9999px;
                font-weight: 600;
                font-size: 0.8rem;
                color: #fff;
                background: rgba(6, 182, 212, 0.1);
                border: 1px solid rgba(6, 182, 212, 0.3);
                transition: all 0.3s ease;
                text-decoration: none;
                width: fit-content;
            }
            .btn-explore:hover {
                background: rgba(6, 182, 212, 0.2);
                border-color: rgba(6, 182, 212, 0.8);
                transform: scale(1.05);
            }

            /* Cybernetic section separation layouts */
            .section-divider {
                height: 2px;
                width: 100%;
                background: linear-gradient(
                    90deg,
                    transparent 0%,
                    rgba(6, 182, 212, 0.6) 50%,
                    transparent 100%
                );
                margin: 4rem 0;
                box-shadow: 0 0 15px rgba(6, 182, 212, 0.4);
            }

            /* Social link components container & hovering micro-interactions */
            .social-link {
                position: relative;
                display: flex;
                align-items: center;
                justify-content: center;
                width: 36px;
                height: 36px;
                color: #94a3b8;
                text-decoration: none;
                border-radius: 50%;
                transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            }
            .social-link svg {
                width: 18px;
                height: 18px;
                transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            }
            .social-link.linkedin:hover {
                background-color: #0a66c2;
                color: #fff;
                transform: scale(1.15) translateY(-3px);
                box-shadow: 0 8px 20px rgba(10, 102, 194, 0.4);
            }
            .social-link.github:hover {
                background-color: #1a1e22;
                color: #fff;
                transform: scale(1.15) translateY(-3px);
                box-shadow: 0 8px 20px rgba(255, 255, 255, 0.15);
            }
            .social-link.whatsapp:hover {
                background-color: #25d366;
                color: #fff;
                transform: scale(1.15) translateY(-3px);
                box-shadow: 0 8px 20px rgba(37, 211, 102, 0.4);
            }

            /* Responsive Device Interaction Utilities */
            .tap-only {
                display: flex;
            }
            .hover-only {
                display: none;
            }
            @media (hover: hover) {
                .tap-only {
                    display: none;
                }
                .hover-only {
                    display: flex;
                }
            }

            /* Soft visual pulsation animation for non-hover displays */
            @keyframes pulse-fade-blur {
                0%,
                100% {
                    opacity: 1;
                    filter: blur(0px);
                }
                50% {
                    opacity: 0.6;
                    filter: blur(0.5px);
                }
            }
            .animate-tap-pulse {
                animation: pulse-fade-blur 2s infinite ease-in-out;
            }
        </style>
    </head>

    <body
        class="min-h-screen flex flex-col relative selection:bg-cyan-500 selection:text-white overflow-x-hidden"
    >
        <!-- Fluid background glow nodes -->
        <div
            class="fixed inset-0 z-0 overflow-hidden pointer-events-none opacity-60"
        >
            <div
                class="absolute top-[-10%] left-[-10%] w-[50rem] h-[50rem] rounded-full bg-blue-600/30 blur-[120px] animate-blob"
            >
            </div>
            <div
                class="absolute top-[20%] right-[-10%] w-[40rem] h-[40rem] rounded-full bg-cyan-500/20 blur-[120px] animate-blob"
                style="animation-delay: 2s;"
            >
            </div>
        </div>

        <!-- Application runtime core injection node -->
        <slot />

        <script is:inline>
            // Graceful execution flag once DOM and layout structures are initialized
            document.addEventListener("DOMContentLoaded", () => {
                document.documentElement.classList.add("loaded");
            });
        </script>
    </body>
</html>
