---
/**
 * src/pages/index.astro
 * * Architecture Layer: Page Orchestrator (Server-Side Rendered)
 */

import Layout from "../layout/Layout.astro";
import Navbar from "../components/Navbar.astro";
import ParticleCanvas from "../components/ParticleCanvas.astro";
import HeroBento from "../components/HeroBento.astro";
import ProjectsGrid from "../components/ProjectsGrid.astro";
import Footer from "../components/Footer.astro";

interface Project {
	_id: string;
	titolo: string;
	descrizione: string;
	tecnologie: string[];
	linkGithub?: string;
}

let projects: Project[] = [];
const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:3002";

try {
	const response = await fetch(`${apiUrl}/api/projects`);

	// Check if the response is actually OK and has content
	if (response.ok) {
		// Read the raw text first to avoid 'Unexpected end of JSON input'
		const rawText = await response.text();
		if (rawText) {
			projects = JSON.parse(rawText);
		}
	} else {
		console.warn(
			`[API Warning] Received non-200 status code: ${response.status}`,
		);
	}
} catch (error) {
	console.error(
		"[Backend Connection Error] Could not fetch projects. Is the backend running?",
	);
}