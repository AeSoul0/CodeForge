---
// ==========================================
// 🧠 SERVER LOGIC (Astro Frontmatter)
// ==========================================
import "../styles/global.css";
import TestBackend from "../components/TestBackend.jsx";

// ⚠️ ADDED 'linkGithub' TO INTERFACE
interface Project {
	_id: string;
	titolo: string;
	descrizione: string;
	tecnologie: string[];
	linkGithub?: string;
}

// Fetch projects from database
let projects: Project[] = [];

// Use environment variable on Vercel, otherwise use localhost for development
const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:3002";

// Fetch projects from database
try {
	const response = await fetch(`${apiUrl}/api/projects`);
	if (response.ok) {
		projects = await response.json();
	}
} catch (error) {
	console.error("Backend connection error:", error);
}
---

<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="AeSoul_favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>CodeForge | ÆSoul</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<style is:global>
			/* 1. Base Reset */
			html,
			body {
				margin: 0;
				padding: 0;
				background-color: #020617;
				color: #e2e8f0;
				font-family: "Outfit", sans-serif;
			}
			body {
				visibility: hidden;
			}
			.loaded body {
				visibility: visible;
			}

			/* 2. Liquid Background Animation */
			@keyframes blob {
				0% {
					transform: translate(0px, 0px) scale(1);
				}
				33% {
					transform: translate(30px, -30px) scale(1.1);
				}
				66% {
					transform: translate(-20px, 20px) scale(0.9);
				}
				100% {
					transform: translate(0px, 0px) scale(1);
				}
			}
			.animate-blob {
				animation: blob 12s infinite alternate ease-in-out;
			}
			.animation-delay-2000 {
				animation-delay: 2s;
			}
			.animation-delay-4000 {
				animation-delay: 4s;
			}

			/* 3. 🔮 REAL GLASSMORPHISM (Frosted Glass) */
			.glass-card {
				background: rgba(255, 255, 255, 0.03);
				backdrop-filter: blur(20px) saturate(160%);
				-webkit-backdrop-filter: blur(20px) saturate(160%);
				border-top: 1px solid rgba(255, 255, 255, 0.1);
				border-left: 1px solid rgba(255, 255, 255, 0.1);
				border-right: 1px solid rgba(255, 255, 255, 0.02);
				border-bottom: 1px solid rgba(255, 255, 255, 0.02);
				box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.4);
				transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
				border-radius: 2rem;
				position: relative;
			}

			/* 4. 💡 BORDER ILLUMINATION (Hover Glow) */
			.hover-glow:hover {
				transform: translateY(-6px);
				border-color: rgba(59, 130, 246, 0.8) !important;
				box-shadow:
					0 15px 35px rgba(0, 0, 0, 0.5),
					0 0 25px rgba(59, 130, 246, 0.3),
					inset 0 0 15px rgba(59, 130, 246, 0.1);
			}

			/* 5. 🔵 EXPLORE BUTTON */
			.btn-explore {
				display: inline-flex;
				align-items: center;
				gap: 0.5rem;
				padding: 0.6rem 1.4rem;
				border-radius: 9999px;
				font-weight: 600;
				font-size: 0.8rem;
				color: #fff;
				background: rgba(6, 182, 212, 0.1);
				border: 1px solid rgba(6, 182, 212, 0.3);
				transition: all 0.3s ease;
				text-decoration: none;
				width: fit-content;
			}
			.btn-explore:hover {
				background: rgba(6, 182, 212, 0.2);
				border-color: rgba(6, 182, 212, 0.8);
				transform: scale(1.05);
			}

			/* 6. 📏 SECTION DIVIDER */
			.section-divider {
				height: 2px;
				width: 100%;
				background: linear-gradient(
					90deg,
					transparent 0%,
					rgba(6, 182, 212, 0.6) 50%,
					transparent 100%
				);
				margin: 4rem 0;
				box-shadow: 0 0 15px rgba(6, 182, 212, 0.4);
			}

			/* 7. 🌟 SMOOTH SOCIAL ANIMATIONS */
			.social-link {
				position: relative;
				display: flex;
				align-items: center;
				justify-content: center;
				width: 36px;
				height: 36px;
				color: #94a3b8;
				text-decoration: none;
				border-radius: 50%;
				transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
			}

			.social-link svg {
				width: 18px;
				height: 18px;
				transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
			}

			.social-link.linkedin:hover {
				background-color: #0a66c2;
				color: whitesmoke;
				transform: scale(1.15) translateY(-3px);
				box-shadow: 0 8px 20px rgba(10, 102, 194, 0.4);
			}
			.social-link.github:hover {
				background-color: #1a1e22;
				color: whitesmoke;
				transform: scale(1.15) translateY(-3px);
				box-shadow: 0 8px 20px rgba(255, 255, 255, 0.15);
			}
			.social-link.whatsapp:hover {
				background-color: #25d366;
				color: whitesmoke;
				transform: scale(1.15) translateY(-3px);
				box-shadow: 0 8px 20px rgba(37, 211, 102, 0.4);
			}

			/* 8. Hover vs Touch Logic */
			.tap-only {
				display: flex;
			}
			.hover-only {
				display: none;
			}
			@media (hover: hover) {
				.tap-only {
					display: none;
				}
				.hover-only {
					display: flex;
				}
			}

			/* 9. Soft Blur Animation for Tap to Reveal */
			@keyframes pulse-fade-blur {
				0%,
				100% {
					opacity: 1;
					filter: blur(0px);
				}
				50% {
					opacity: 0.6;
					filter: blur(0.5px);
				} /* Reduced blur and increased opacity for comfort */
			}
			.animate-tap-pulse {
				animation: pulse-fade-blur 2s infinite ease-in-out;
			}

			#particleCanvas {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: 1;
				pointer-events: none;
			}
		</style>
	</head>

