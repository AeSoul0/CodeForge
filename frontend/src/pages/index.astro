---
/**
 * @file src/pages/index.astro
 * @description Core Entry Routing Node orchestrating layouts and fetching structural mock records[cite: 1, 2].
 */

import Layout from "../layout/Layout.astro";
import Navbar from "../components/Navbar.astro";
import ParticleCanvas from "../components/ParticleCanvas.astro";
import HeroBento from "../components/HeroBento.astro";
import ProjectsGrid from "../components/ProjectsGrid.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

// Interface map enforcing strong type metrics for visual rendering
interface Project {
	_id: string;
	titolo: string;
	descrizione: string;
	tecnologie: string[];
	linkGithub?: string;
}

let projects: Project[] = [];
const apiUrl = import.meta.env.PUBLIC_API_URL || "http://localhost:3002";

// Server-side fetching structure connecting frontend modules to database APIs[cite: 1, 2]
try {
	const response = await fetch(`${apiUrl}/api/projects`);
	if (response.ok) {
		const rawData = await response.text();
		if (rawData) {
			projects = JSON.parse(rawData);
		}
	} else {
		console.warn(
			`[API Warning] Received non-200 operational status: ${response.status}`,
		);
	}
} catch (error) {
	// Gracefully log communication errors without breaking critical layout assemblies[cite: 1]
	console.error(
		"[Backend Connection Error] Failed to stream dashboard logs:",
		error,
	);
}
---

<Layout title="CodeForge | ÆSoul">
	<!-- Interactive Canvas Engine Layer -->
	<ParticleCanvas />

	<!-- Navigation Layer -->
	<Navbar />

	<!-- Semantic Content Module Frame -->
	<main
		class="max-w-6xl mx-auto px-6 py-4 flex-grow relative z-10 pointer-events-auto w-full"
	>
		<!-- Visual Bento Hub Section -->
		<HeroBento />

		<!-- Visual Linear Segmenter -->
		<div class="section-divider"></div>

		<!-- Dynamic Showcase Pipeline Section -->
		<ProjectsGrid projects={projects} />

		<!-- Visual Linear Segmenter -->
		<div class="section-divider"></div>
	</main>

	<!-- Ground Footer Layer -->
	<Footer />
</Layout>
