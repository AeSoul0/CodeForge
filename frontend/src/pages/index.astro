									</h3>
									<p class="text-slate-300 text-sm leading-relaxed mb-8 relative z-10">
										{project.descrizione}
									</p>

									<div class="flex flex-wrap gap-3 relative z-10">
										{project.tecnologie.map((tech) => (
											<span class="px-4 py-2 text-xs font-bold bg-slate-900/40 text-cyan-400 rounded-full border border-white/10 shadow-lg shadow-cyan-900/10 cursor-default transition-all duration-300 ease-out hover:-translate-y-1 hover:scale-105 hover:border-blue-400 hover:bg-blue-500/10 hover:shadow-[0_0_15px_rgba(59,130,246,0.5)] uppercase tracking-wide backdrop-blur-md">
												{tech}
											</span>
										))}
									</div>
								</article>
							))}
						</div>
					)
				}
			</section>
		</main>

		<footer
			class="max-w-6xl mx-auto px-6 py-12 w-full border-t border-slate-800/50 flex flex-col md:flex-row justify-between items-center gap-6 text-sm relative z-10"
		>
			<div class="flex items-center gap-2 text-slate-500">
				<span>&copy; 2026</span>
				<span
					class="font-bold tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-600 drop-shadow-sm"
				>
					ÆSouls
				</span>
			</div>
			<div class="text-slate-500 text-center md:text-right">
				<p>
					Forgiato con passione &bull; <span
						class="text-slate-400 font-mono">CodeForge v1.0</span>
				</p>
			</div>
		</footer>

		<script is:inline>
			document.addEventListener("DOMContentLoaded", () => {
				document.documentElement.classList.add("loaded");

				// ==========================================
				// 💡 LOGICA SWITCH TEMA (JS NATIVO)
				// ==========================================
				const themeToggle = document.getElementById("theme-checkbox");
				const htmlElement = document.documentElement;

				// Controlla il localStorage per ricordare la scelta
				const savedTheme = localStorage.getItem("theme");
				if (savedTheme === "light") {
					htmlElement.classList.add("light-mode");
					themeToggle.checked = false;
				} else {
					themeToggle.checked = true;
				}

				// Al click cambia classe e salva nel browser
				themeToggle.addEventListener("change", (e) => {
					if (!e.target.checked) {
						htmlElement.classList.add("light-mode");
						localStorage.setItem("theme", "light");
					} else {
						htmlElement.classList.remove("light-mode");
						localStorage.setItem("theme", "dark");
					}
				});

				// ==========================================
				// 🧬 LOGICA RETE NEURALE (PARTICELLE)
				// ==========================================
				const canvas = document.getElementById("particleCanvas");
				const ctx = canvas.getContext("2d");
				let width, height;
				let particles = [];
				let mouse = { x: null, y: null };

				function resize() {
					width = canvas.width = window.innerWidth;
					height = canvas.height = window.innerHeight;
				}
				window.addEventListener("resize", resize);
				resize();

				window.addEventListener("mousemove", (e) => {
					mouse.x = e.clientX;
					mouse.y = e.clientY;
				});
				window.addEventListener("mouseout", () => {
					mouse.x = null;
					mouse.y = null;
				});

				class Particle {
					constructor() {
						this.x = Math.random() * width;
						this.y = Math.random() * height;
						this.vx = (Math.random() - 0.5) * 0.8;
						this.vy = (Math.random() - 0.5) * 0.8;
						this.radius = Math.random() * 1.5 + 0.5;
						this.baseColor =
							Math.random() > 0.5
								? "6, 182, 212"
								: "59, 130, 246";
					}
					update() {
						this.x += this.vx;
						this.y += this.vy;
						if (this.x < 0 || this.x > width) this.vx = -this.vx;
						if (this.y < 0 || this.y > height) this.vy = -this.vy;
					}
					draw() {
						ctx.beginPath();
						ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
						ctx.fillStyle = `rgba(${this.baseColor}, 0.8)`;
						ctx.fill();
					}
				}

				for (let i = 0; i < 80; i++) {
					particles.push(new Particle());
				}

				function animate() {
					ctx.clearRect(0, 0, width, height);
					for (let i = 0; i < particles.length; i++) {
						particles[i].update();
						particles[i].draw();

						for (let j = i; j < particles.length; j++) {
							let dx = particles[i].x - particles[j].x;
							let dy = particles[i].y - particles[j].y;
							let distance = Math.sqrt(dx * dx + dy * dy);
							if (distance < 100) {
								ctx.beginPath();
								ctx.strokeStyle = `rgba(${particles[i].baseColor}, ${0.2 - distance / 500})`;
								ctx.lineWidth = 1;
								ctx.moveTo(particles[i].x, particles[i].y);
								ctx.lineTo(particles[j].x, particles[j].y);
								ctx.stroke();
							}
						}

						if (mouse.x != null && mouse.y != null) {
							let dx = particles[i].x - mouse.x;
							let dy = particles[i].y - mouse.y;
							let distance = Math.sqrt(dx * dx + dy * dy);
							if (distance < 150) {
								ctx.beginPath();
								ctx.strokeStyle = `rgba(6, 182, 212, ${0.4 - distance / 375})`;
								ctx.lineWidth = 1.2;
								ctx.moveTo(particles[i].x, particles[i].y);
								ctx.lineTo(mouse.x, mouse.y);
								ctx.stroke();
							}
						}
					}
					requestAnimationFrame(animate);
				}
				animate();
			});
		</script>
	</body>
</html>
