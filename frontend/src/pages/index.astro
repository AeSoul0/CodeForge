---
// ==========================================
// 🧠 LOGICA DEL SERVER (Astro Frontmatter)
// ==========================================

import "../styles/global.css";
import TestBackend from "../components/TestBackend.jsx";

interface Project {
	_id: string;
	titolo: string;
	descrizione: string;
	tecnologie: string[];
}

let projects: Project[] = [];

try {
	const response = await fetch("http://localhost:3002/api/projects");
	if (response.ok) {
		projects = await response.json();
	}
} catch (error) {
	console.error("Errore di connessione al backend:", error);
}
---

<html lang="it" class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="AEsouls_favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<title>CodeForge | ÆSouls Portfolio</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>

		<style is:global>
			html,
			body {
				transition:
					background-color 0.5s ease,
					color 0.5s ease;
			}
			html {
				background-color: #020617;
				color: #e2e8f0;
			}
			body {
				visibility: hidden;
			}
			.loaded body {
				visibility: visible;
			}

			/* Sfondo Animato Liquido */
			@keyframes blob {
				0% {
					transform: translate(0px, 0px) scale(1);
				}
				33% {
					transform: translate(50px, -50px) scale(1.1);
				}
				66% {
					transform: translate(-40px, 40px) scale(0.9);
				}
				100% {
					transform: translate(0px, 0px) scale(1);
				}
			}
			.animate-blob {
				animation: blob 15s infinite alternate ease-in-out;
			}
			.animation-delay-2000 {
				animation-delay: 2s;
			}
			.animation-delay-4000 {
				animation-delay: 4s;
			}

			@keyframes bounce-pop {
				0% {
					transform: scale(1);
				}
				40% {
					transform: scale(1.3);
				}
				60% {
					transform: scale(0.85);
				}
				80% {
					transform: scale(1.1);
				}
				100% {
					transform: scale(1);
				}
			}
			.hover-bounce:hover {
				animation: bounce-pop 0.4s linear forwards;
				transform-origin: center;
			}

			#particleCanvas {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				z-index: 1;
				pointer-events: none;
			}

			/* ========================================== */
			/* 🔮 1. VERO GLASSMORPHISM (Frosted Glass)   */
			/* ========================================== */
			.glass-card {
				/* Un leggerissimo tocco di bianco invece del nero, crea l'effetto lastra di vetro */
				background: linear-gradient(
					135deg,
					rgba(255, 255, 255, 0.05) 0%,
					rgba(255, 255, 255, 0.01) 100%
				);
				backdrop-filter: blur(24px);
				-webkit-backdrop-filter: blur(24px);
				/* Riflesso sui bordi superiore e sinistro come vero vetro illuminato */
				border-top: 1px solid rgba(255, 255, 255, 0.15);
				border-left: 1px solid rgba(255, 255, 255, 0.15);
				border-right: 1px solid rgba(255, 255, 255, 0.05);
				border-bottom: 1px solid rgba(255, 255, 255, 0.05);
				box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
				transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
			}

			/* ========================================== */
			/* 💡 2. GLOW ILLUMINAZIONE INFALLIBILE       */
			/* ========================================== */
			.hover-glow:hover {
				transform: translateY(-8px);
				border-color: rgba(59, 130, 246, 0.8) !important;
				box-shadow:
					0 8px 32px 0 rgba(0, 0, 0, 0.3),
					0 0 30px 5px rgba(59, 130, 246, 0.5),
					inset 0 0 15px rgba(59, 130, 246, 0.2) !important;
			}

			/* ========================================== */
			/* 🌙 3. SWITCH TEMA AD-HOC PER CODEFORGE     */
			/* ========================================== */
			.cf-theme-switch {
				cursor: pointer;
				display: flex;
				align-items: center;
				-webkit-tap-highlight-color: transparent;
			}
			.cf-theme-switch input {
				display: none;
			}

			.cf-switch-track {
				width: 60px;
				height: 30px;
				background: rgba(15, 23, 42, 0.8);
				border: 1px solid rgba(255, 255, 255, 0.1);
				border-radius: 30px;
				position: relative;
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 0 6px;
				box-shadow: inset 0 2px 5px rgba(0, 0, 0, 0.5);
			}

			.cf-switch-icon {
				width: 14px;
				height: 14px;
				color: #94a3b8;
				z-index: 1;
				transition: color 0.3s;
			}

			.cf-switch-thumb {
				position: absolute;
				top: 3px;
				left: 3px;
				width: 22px;
				height: 22px;
				background: linear-gradient(135deg, #0ea5e9, #3b82f6);
				border-radius: 50%;
				transition: 0.4s cubic-bezier(0.25, 1, 0.5, 1);
				box-shadow: 0 0 10px rgba(14, 165, 233, 0.6);
				z-index: 2;
			}

			.cf-theme-switch input:checked + .cf-switch-track .cf-switch-thumb {
				transform: translateX(30px);
				background: linear-gradient(135deg, #3b82f6, #8b5cf6);
				box-shadow: 0 0 10px rgba(59, 130, 246, 0.6);
			}

			/* ========================================== */
			/* ☀️ 4. LIGHT MODE OVERRIDES                 */
			/* ========================================== */
			html.light-mode body {
				background-color: #f8fafc !important; /* Grigio super chiaro */
				color: #0f172a !important; /* Testo scuro */
			}

			html.light-mode .text-white {
				color: #0f172a !important;
			}
			html.light-mode .text-slate-200 {
				color: #1e293b !important;
			}
			html.light-mode .text-slate-300 {
				color: #334155 !important;
			}
			html.light-mode .text-slate-400 {
				color: #475569 !important;
			}

			/* Blob più visibili in light mode */
			html.light-mode .blob-1 {
				background-color: rgba(99, 102, 241, 0.5);
			}
			html.light-mode .blob-2 {
				background-color: rgba(6, 182, 212, 0.4);
			}
			html.light-mode .blob-3 {
				background-color: rgba(59, 130, 246, 0.4);
			}

			/* Vetro versione Light */
			html.light-mode .glass-card {
				background: linear-gradient(
					135deg,
					rgba(255, 255, 255, 0.7) 0%,
					rgba(255, 255, 255, 0.4) 100%
				);
				border-top: 1px solid rgba(255, 255, 255, 1);
				border-left: 1px solid rgba(255, 255, 255, 1);
				box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.1);
			}

			/* Adattamento bottoni social nella navbar in Light Mode */
			html.light-mode nav .glass-panel {
				background-color: rgba(255, 255, 255, 0.8) !important;
				border-color: rgba(0, 0, 0, 0.1) !important;
			}
			html.light-mode .bg-slate-900\/40 {
				background-color: rgba(255, 255, 255, 0.7) !important;
			}
		</style>
	</head>

	<body
		class="bg-slate-950 text-slate-200 min-h-screen flex flex-col selection:bg-cyan-500 selection:text-white relative"
		style="font-family: 'Outfit', sans-serif;"
	>
		<div
			class="fixed inset-0 z-0 overflow-hidden pointer-events-none opacity-80"
		>
			<div
				class="blob-1 absolute top-[-10%] left-[-10%] w-[40rem] h-[40rem] rounded-full bg-indigo-600/40 blur-[120px] animate-blob"
			>
			</div>
			<div
				class="blob-2 absolute top-[20%] right-[-10%] w-[35rem] h-[35rem] rounded-full bg-cyan-500/30 blur-[120px] animate-blob animation-delay-2000"
			>
			</div>
			<div
				class="blob-3 absolute bottom-[-20%] left-[20%] w-[45rem] h-[45rem] rounded-full bg-blue-600/30 blur-[150px] animate-blob animation-delay-4000"
